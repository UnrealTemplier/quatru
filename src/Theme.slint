// Theme.slint — Премиальная тёмная тема (Spotify / DAW стиль)

export global Theme {
    // Цвета
    in-out property<color> color-bg-primary: #0a0a0a;
    in-out property<color> color-bg-surface: #121212;
    in-out property<color> color-bg-elevated: #1a1a1a;
    in-out property<color> color-bg-overlay: #242424;
    in-out property<color> color-accent: #1db954;
    in-out property<color> color-accent-hover: #1ed760;
    in-out property<color> color-text-primary: #ffffff;
    in-out property<color> color-text-secondary: #b3b3b3;
    in-out property<color> color-text-disabled: #535353;
    in-out property<color> color-border: #282828;
    in-out property<color> color-progress-track: #404040;
    in-out property<color> color-progress-fill: #1db954;

    // Размеры
    in-out property<length> window-width: 1200px;
    in-out property<length> window-height: 800px;
    in-out property<length> control-bar-height: 72px;
    in-out property<length> control-padding: 16px;
    in-out property<length> progress-bar-height: 6px;
    in-out property<length> button-size: 40px;
    in-out property<length> border-radius: 8px;

    // Шрифты
    in-out property<string> font-family: "Inter";
    in-out property<length> font-size-small: 12px;
    in-out property<length> font-size-medium: 14px;
    in-out property<length> font-size-large: 18px;
}
